              "apiVersion": "2021-03-01",
              "name": "[variables('authCustomOperationsFunctionAppName')]",
              "location": "[parameters('location')]",
              "kind": "functionapp,linux",
              "identity": {
                "type": "SystemAssigned"
              },
              "properties": {
                "httpsOnly": true,
                "enabled": true,
                "serverFarmId": "[parameters('hostingPlanId')]",
                "reserved": true,
                "clientAffinityEnabled": false,
                "siteConfig": "[variables('siteConfig')]"
              },
              "tags": "[union(parameters('appTags'), createObject('azd-service-name', 'auth'))]",
              "metadata": {
                "description": "Azure Function used to run auth flow custom operations using the Azure Health Data Services Toolkit"
              }
            },
            {
              "type": "Microsoft.Web/sites/config",
              "apiVersion": "2020-12-01",
              "name": "[format('{0}/{1}', variables('authCustomOperationsFunctionAppName'), 'appsettings')]",
              "properties": {
                "AzureWebJobsStorage": "[format('DefaultEndpointsProtocol=https;AccountName={0};EndpointSuffix={1};AccountKey={2}', parameters('customOperationsFuncStorName'), environment().suffixes.storage, listKeys(resourceId('Microsoft.Storage/storageAccounts', parameters('customOperationsFuncStorName')), '2021-08-01').keys[0].value)]",
                "FUNCTIONS_EXTENSION_VERSION": "~4",
                "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated",
                "APPLICATIONINSIGHTS_CONNECTION_STRING": "[parameters('appInsightsConnectionString')]",
                "SCM_DO_BUILD_DURING_DEPLOYMENT": "false",
                "ENABLE_ORYX_BUILD": "true",
                "AZURE_APPLICATIONINSIGHTS_CONNECTION_STRING": "[parameters('appInsightsConnectionString')]",
                "AZURE_Authority_URL": "[parameters('authorityUrl')]",
                "AZURE_FhirServerUrl": "[parameters('fhirServiceUrl')]",
                "AZURE_FhirAudience": "[parameters('fhirServiceAudience')]",
                "AZURE_UserIdClaimType": "[parameters('userIdClaimType')]",
                "AZURE_ContextAppClientId": "[parameters('contextAadApplicationId')]",
                "AZURE_CacheConnectionString": "[format('{0},password={1},ssl=True,abortConnect=False', parameters('redisCacheHostName'), listKeys(parameters('redisCacheId'), parameters('redisApiVersion')).primaryKey)]",
                "AZURE_Debug": "true"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Web/sites', variables('authCustomOperationsFunctionAppName'))]"
              ]
            }
          ],
          "outputs": {
            "functionAppUrl": {
              "type": "string",
              "value": "[format('https://{0}/api', reference(resourceId('Microsoft.Web/sites', variables('authCustomOperationsFunctionAppName')), '2021-03-01').defaultHostName)]"
            },
            "functionAppPrincipalId": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Web/sites', variables('authCustomOperationsFunctionAppName')), '2021-03-01', 'full').identity.principalId]"
            },
            "authCustomOperationAudience": {
              "type": "string",
              "value": "[parameters('fhirServiceAudience')]"
            },
            "cacheConnectionString": {
              "type": "string",
              "value": "[format('{0},password={1},ssl=True,abortConnect=False', parameters('redisCacheHostName'), listKeys(parameters('redisCacheId'), parameters('redisApiVersion')).primaryKey)]"
            }
          }
        }
      },
      "dependsOn": [
        "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('resourceGroupName')), 'Microsoft.Resources/deployments', 'functionBaseDeploy')]",
        "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('resourceGroupName')), 'Microsoft.Resources/deployments', 'monitoringDeploy')]",
        "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('resourceGroupName')), 'Microsoft.Resources/deployments', 'redisDeploy')]",
        "[subscriptionResourceId('Microsoft.Resources/resourceGroups', format('{0}-rg', parameters('name')))]"
      ]
    }
  ],
  "outputs": {
    "AZURE_RESOURCE_GROUP": {
      "type": "string",
      "value": "[variables('resourceGroupName')]"
    },
    "FhirUrl": {
      "type": "string",
      "value": "[variables('fhirUrl')]"
    },
    "FhirAudience": {
      "type": "string",
      "value": "[variables('fhirAudienceResolved')]"
    },
    "FunctionBaseUrl": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('resourceGroupName')), 'Microsoft.Resources/deployments', 'authCustomOperationDeploy'), '2022-09-01').outputs.functionAppUrl.value]"
    },
    "FunctionAppManagedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('resourceGroupName')), 'Microsoft.Resources/deployments', 'authCustomOperationDeploy'), '2022-09-01').outputs.functionAppPrincipalId.value]"
    },
    "CacheConnectionString": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('resourceGroupName')), 'Microsoft.Resources/deployments', 'authCustomOperationDeploy'), '2022-09-01').outputs.cacheConnectionString.value]"
    }
  }
}