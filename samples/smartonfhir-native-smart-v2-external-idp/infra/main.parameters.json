{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "ContextAppClientId": {
      "value": "${ContextAppClientId=}"
    },
    "FhirAudience": {
      "value": "${FhirAudience}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "name": {
      "value": "${AZURE_ENV_NAME}"
    },
    "AuthorityURL": {
      "value": "${AuthorityURL}"
    },
    "UserIdClaimType": {
      "value": "${UserIdClaimType=sub}"
    }
  }
}