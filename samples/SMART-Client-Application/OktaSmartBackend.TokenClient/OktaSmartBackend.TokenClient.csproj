<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>OktaSmartBackend.TokenClient</RootNamespace>
    <Description>SMART Backend Services token helper: Okta client_credentials + private_key_jwt (ES384). Referenced by SmartOnFhirDemo.</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="System.IdentityModel.Tokens.Jwt" Version="7.6.3" />
  </ItemGroup>
</Project>
